# =============================================================================
# DAC Dual Node — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Blockchain & Node Data
# -----------------------------------------------------------------------------
chaindata/
lightchaindata/
nodes/
triecache/
*.ipc
*.ldb
LOCK
MANIFEST-*

# -----------------------------------------------------------------------------
# Keys & Sensitive Data  ⚠️  NEVER commit these
# -----------------------------------------------------------------------------
keystore/
password.txt
*.key
*.pem
secrets/
.env
.env.*

# -----------------------------------------------------------------------------
# Configuration with Sensitive Values
# -----------------------------------------------------------------------------
# *.json is excluded to protect keystore files.
# If you need to track specific JSON configs, use:
#   git add -f your-config.json
*.json

# -----------------------------------------------------------------------------
# Logs & Runtime Files
# -----------------------------------------------------------------------------
*.log
*.pid
nohup.out
debug.log
geth.log

# -----------------------------------------------------------------------------
# Build & Binary Outputs
# -----------------------------------------------------------------------------
dacnode
dacnode.exe
*.exe
*.out
build/
dist/

# -----------------------------------------------------------------------------
# OS-Specific
# -----------------------------------------------------------------------------

# Windows
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Linux / WSL
*~
.nfs*

# -----------------------------------------------------------------------------
# Editor & IDE
# -----------------------------------------------------------------------------

# VS Code
.vscode/
*.code-workspace

# JetBrains (GoLand, etc.)
.idea/
*.iml

# Vim / Neovim
*.swp
*.swo
Session.vim

# -----------------------------------------------------------------------------
# Miscellaneous
# -----------------------------------------------------------------------------
*.bak
*.tmp
*.orig
