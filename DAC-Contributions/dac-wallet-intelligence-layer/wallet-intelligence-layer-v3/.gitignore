# Wallet Intelligence Layer v3 local gitignore
# Root repo ignores *.json globally, so v3 explicitly allows rank artifacts.

!data/
!data/wallet-rank-summary.json
!data/wallet-rank-index.json
!data/source-wallet-metrics.sample.json

# Python cache
__pycache__/
*.pyc

# Wallet metrics collector artifacts
!data/wallet-addresses.sample.txt
!data/source-wallet-metrics.generated.json

# Wallet discovery artifacts
!data/wallet-addresses.generated.txt
!data/wallet-discovery-summary.json

# Full Explorer address rank indexer work/cache
data/indexer-work/

# Published rank shards
!data/rank-shards/
!data/rank-shards/*.json
